<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net9.0-windows10.0.19041.0</TargetFramework>
    <SupportedOSPlatformVersion>10.0.19041.0</SupportedOSPlatformVersion>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <AssemblyName>rst</AssemblyName>
    <OutputPath>app</OutputPath>
    <AppendTargetFrameworkToOutputPath>false</AppendTargetFrameworkToOutputPath>
    <AppendRuntimeIdentifierToOutputPath>false</AppendRuntimeIdentifierToOutputPath>
    <RootNamespace>WPFScreenCapture</RootNamespace>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <EnableDefaultPageItems>false</EnableDefaultPageItems>
    <ApplicationIcon>media\AppIcon.ico</ApplicationIcon>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <PublishSingleFile>true</PublishSingleFile>
    <SelfContained>true</SelfContained>
    <ApplicationManifest>app.manifest</ApplicationManifest>

    <!-- Assembly metadata — helps AV heuristics identify the binary as legitimate -->
    <Version>4.6.0</Version>
    <FileVersion>4.6.0.0</FileVersion>
    <AssemblyVersion>4.6.0.0</AssemblyVersion>
    <Company>RSTGameTranslation</Company>
    <Product>RST Game Translation</Product>
    <Authors>RSTGameTranslation</Authors>
    <Description>Real-time game screen OCR and translation tool</Description>
    <AssemblyTitle>RST Game Translation</AssemblyTitle>
    <Copyright>Copyright © 2024-2026 RSTGameTranslation. All rights reserved.</Copyright>

    <!-- Include PDB for deterministic builds — AV engines trust binaries with debug info -->
    <!-- Note: CsWinRT IIDOptimizer requires a separate PDB file, so use 'portable' not 'embedded' -->
    <DebugType>portable</DebugType>
    <DebugSymbols>true</DebugSymbols>

    <!-- Deterministic build — identical source always produces identical binary (improves AV trust) -->
    <Deterministic>true</Deterministic>

    <!-- Disable IL trimming to avoid AV heuristic false-positives from trimmed assemblies -->
    <PublishTrimmed>false</PublishTrimmed>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)'=='Debug'">
    <AssemblyName>rst_debug</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Hardcodet.NotifyIcon.Wpf" Version="2.0.1" />
    <PackageReference Include="Microsoft.Windows.CsWinRT" Version="2.0.6" />
    <PackageReference Include="NAudio" Version="2.2.1" />
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="SocketIOClient" Version="3.1.2" />
    <PackageReference Include="System.Management" Version="7.0.1" />
    <PackageReference Include="System.Speech" Version="9.0.9" />
    <PackageReference Include="Whisper.net" Version="1.9.0" />
    <PackageReference Include="Whisper.net.Runtime" Version="1.9.0" />
    <PackageReference Include="Whisper.net.Runtime.Cuda.Windows" Version="1.9.0" />
    <PackageReference Include="Whisper.net.Runtime.Vulkan" Version="1.9.0" />
  </ItemGroup>
  
  <ItemGroup>
    <Compile Include="src\**\*.cs" />
    <None Remove="src\**\*.xaml" />
    <ApplicationDefinition Include="src\App.xaml" />
    <Page Include="src\**\*.xaml" Exclude="src\App.xaml" />
    <None Include="app.manifest" />
  </ItemGroup>
  
  <ItemGroup>
    <Resource Include="media\AppIcon.ico" />
  </ItemGroup>

</Project>
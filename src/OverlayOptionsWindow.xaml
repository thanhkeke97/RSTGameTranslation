<Window x:Class="RSTGameTranslation.OverlayOptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RSTGameTranslation"
        mc:Ignorable="d"
        Title="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[OverlayOptions_Title]}" Height="450" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="/media/AppIcon.ico">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Surface3Brush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Surface2Brush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[OverlayOptions_Header]}" 
                   Grid.Row="0"
                   FontSize="16" 
                   FontWeight="SemiBold" 
                   Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Background settings -->
                <GroupBox Header="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[OverlayOptions_Grp_Background]}" Margin="0,5,0,10" Padding="5">
                    <StackPanel>
                        <DockPanel Margin="0,5">
                            <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[OverlayOptions_Lbl_BackgroundColor]}" VerticalAlignment="Center" Width="120" />
                            <Button x:Name="backgroundColorButton" 
                                    Width="30" Height="20" 
                                    Margin="5,0,0,0"
                                    Click="BackgroundColorButton_Click"/>
                            <TextBlock x:Name="backgroundColorText" 
                                       Text="#80000000" 
                                       VerticalAlignment="Center" 
                                       Margin="10,0,0,0"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>

                <!-- Text settings -->
                <GroupBox Header="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[OverlayOptions_Grp_Text]}" Margin="0,5,0,10" Padding="5">
                    <StackPanel>                   
                        <DockPanel Margin="0,5">
                            <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[OverlayOptions_Lbl_TextColor]}" VerticalAlignment="Center" Width="120" />
                            <Button x:Name="textColorButton" 
                                    Width="30" Height="20" 
                                    Margin="5,0,0,0"
                                    Click="TextColorButton_Click"/>
                            <TextBlock x:Name="textColorText" 
                                       Text="#FFFFFFFF" 
                                       VerticalAlignment="Center" 
                                       Margin="10,0,0,0"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>

                <!-- Font settings -->
                <GroupBox Header="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[OverlayOptions_Grp_Font]}" Margin="0,5,0,10" Padding="5">
                    <StackPanel>
                        <DockPanel Margin="0,5">
                            <!-- Language Font Override -->
                            <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[OverlayOptions_Lbl_FontOverride]}"
                                       VerticalAlignment="Center" 
                                       Width="120"/>
                            <CheckBox x:Name="languageFontOverrideCheckBox" 
                                      Margin="5,0,0,0" />
                        </DockPanel>
                        <DockPanel Margin="0,5">
                            <!-- Language Font Family -->
                            <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[OverlayOptions_Lbl_SelectFont]}" 
                                       VerticalAlignment="Center" 
                                       Width="120"/>
                            <ComboBox x:Name="languageFontFamilyComboBox" 
                                      Margin="5,0,0,0"/>
                        </DockPanel>
                        <DockPanel Margin="0,5">
                            <!-- Font Size Min -->
                            <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[OverlayOptions_Lbl_FontSizeMin]}" 
                                       VerticalAlignment="Center" 
                                       Width="120"/>
                            <TextBox x:Name="languageFontSizeMinTextBox" 
                                     Text="10" 
                                     Margin="5,0,0,0"/>
                        </DockPanel>
                        <DockPanel Margin="0,5">
                            <!-- Font Size Max -->
                            <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[OverlayOptions_Lbl_FontSizeMax]}" 
                                       VerticalAlignment="Center" 
                                       Width="120"/>
                            <TextBox x:Name="languageFontSizeMaxTextBox" 
                                     Text="68" 
                                     Margin="5,0,0,0"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons section -->
        <Grid Grid.Row="2" Margin="0,15,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Button x:Name="defaultsButton"
                    Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[OverlayOptions_Btn_SetDefaults]}"
                    Width="100"
                    HorizontalAlignment="Left"
                    Click="DefaultsButton_Click"
                    ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[OverlayOptions_Tip_SetDefaults]}"
                    Grid.Column="0"/>
            
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Grid.Column="1">
                <Button x:Name="applyButton"
                        Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[OverlayOptions_Btn_Apply]}"
                        Width="80"
                        Margin="5,0"
                        Click="ApplyButton_Click"/>
                <Button x:Name="cancelButton"
                        Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[OverlayOptions_Btn_Cancel]}"
                        Width="80"
                        Margin="5,0"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
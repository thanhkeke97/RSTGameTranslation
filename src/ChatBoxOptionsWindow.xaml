<Window x:Class="RSTGameTranslation.ChatBoxOptionsWindow"         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RSTGameTranslation"
        mc:Ignorable="d"
        Title="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Title]}" Height="450" Width="400"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Icon="/media/AppIcon.ico">
    
    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="{DynamicResource Surface3Brush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,8"/>
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"
                                              RecognizesAccessKey="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="{DynamicResource Surface2Brush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Header]}"
                   Grid.Row="0"
                   FontSize="16" 
                   FontWeight="SemiBold" 
                   Margin="0,0,0,10"/>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Background settings -->
                <GroupBox Header="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Grp_Background]}" Margin="0,5,0,10" Padding="5">
                    <StackPanel>
                        <DockPanel Margin="0,5">
                            <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Lbl_BackgroundColor]}" VerticalAlignment="Center" Width="120" />
                            <Button x:Name="backgroundColorButton" 
                                    Width="30" Height="20" 
                                    Margin="5,0,0,0"
                                    Click="BackgroundColorButton_Click"/>
                            <TextBlock x:Name="backgroundColorText" 
                                       Text="#80000000" 
                                       VerticalAlignment="Center" 
                                       Margin="10,0,0,0"/>
                        </DockPanel>
                        
                        <DockPanel Margin="0,5">
                            <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Lbl_BackgroundOpacity]}" VerticalAlignment="Center" Width="120" />
                            <Slider x:Name="backgroundOpacitySlider" 
                                    Minimum="0" Maximum="1" 
                                    Value="0.5" 
                                    Width="150" 
                                    TickPlacement="BottomRight"
                                    TickFrequency="0.05"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="BackgroundOpacitySlider_ValueChanged"/>
                            <TextBlock x:Name="backgroundOpacityText" 
                                       Text="50%" 
                                       VerticalAlignment="Center" 
                                       Margin="10,0,0,0"/>
                        </DockPanel>
                        
                        <DockPanel Margin="0,5">
                            <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Lbl_WindowOpacity]}" VerticalAlignment="Center" Width="120" />
                            <Slider x:Name="windowOpacitySlider" 
                                    Minimum="0.1" Maximum="1" 
                                    Value="1.0" 
                                    Width="150" 
                                    TickPlacement="BottomRight"
                                    TickFrequency="0.1"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="WindowOpacitySlider_ValueChanged"/>
                            <TextBlock x:Name="windowOpacityText" 
                                       Text="100%" 
                                       VerticalAlignment="Center" 
                                       Margin="10,0,0,0"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>

                <!-- Text settings -->
                <GroupBox Header="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Grp_Text]}" Margin="0,5,0,10" Padding="5">
                    <StackPanel>
                        <DockPanel Margin="0,5">
                            <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Lbl_FontFamily]}" VerticalAlignment="Center" Width="120" />
                            <ComboBox x:Name="fontFamilyComboBox" 
                                      Width="200" 
                                      SelectionChanged="FontFamilyComboBox_SelectionChanged"/>
                        </DockPanel>
                        
                        <DockPanel Margin="0,5">
                            <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Lbl_FontSize]}" VerticalAlignment="Center" Width="120" />
                            <Slider x:Name="fontSizeSlider" 
                                    Minimum="8" Maximum="48" 
                                    Value="14" 
                                    Width="150" 
                                    TickPlacement="BottomRight"
                                    TickFrequency="2"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="FontSizeSlider_ValueChanged"/>
                            <TextBlock x:Name="fontSizeText" 
                                       Text="14" 
                                       VerticalAlignment="Center" 
                                       Margin="10,0,0,0"/>
                        </DockPanel>

                        <DockPanel Margin="0,5">
                            <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Lbl_AutoClear]}" VerticalAlignment="Center" Width="120" />
                            <CheckBox x:Name="autoClearChatboxHistoryCheckBox" Grid.Row="3" Grid.Column="1"
                                         Margin="0,5" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Tip_AutoClear]}"
                                         Checked="autoClearChatboxHistoryCheckBox_CheckedChanged"
                                         Unchecked="autoClearChatboxHistoryCheckBox_CheckedChanged"/>
                        </DockPanel>

                        <DockPanel Margin="0,5">
                            <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Lbl_AutoClearTimeout]}" VerticalAlignment="Center" Width="120" />
                            <Slider x:Name="autoClearTimeoutSlider"
                                    Minimum="0" Maximum="60"
                                    Value="30"
                                    Width="120"
                                    TickPlacement="BottomRight"
                                    TickFrequency="5"
                                    IsSnapToTickEnabled="True"
                                    ValueChanged="AutoClearTimeoutSlider_ValueChanged"/>
                            <TextBlock x:Name="autoClearTimeoutText"
                                       Text="30s"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"/>
                        </DockPanel>

                        <DockPanel Margin="0,5">
                            <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Lbl_RecreateOnShow]}" VerticalAlignment="Center" Width="120" TextWrapping="Wrap" />
                            <CheckBox x:Name="recreateChatboxCheckBox" Grid.Row="4" Grid.Column="1"
                                      Margin="0,5" ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Tip_RecreateOnShow]}"
                                      Checked="recreateChatboxCheckBox_CheckedChanged"
                                      Unchecked="recreateChatboxCheckBox_CheckedChanged"/>
                        </DockPanel>
                    </StackPanel>
                </GroupBox>

                <!-- Original text color -->
                <GroupBox Header="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Grp_OriginalText]}" Margin="0,5,0,10" Padding="5">
                    <DockPanel Margin="0,5">
                        <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Lbl_TextColor]}" VerticalAlignment="Center" Width="120" />
                        <Button x:Name="originalTextColorButton" 
                                Width="30" Height="20" 
                                Margin="5,0,0,0"
                                Click="OriginalTextColorButton_Click"/>
                        <TextBlock x:Name="originalTextColorText" 
                                   Text="#FFF8E0A0" 
                                   VerticalAlignment="Center" 
                                   Margin="10,0,0,0"/>
                    </DockPanel>
                </GroupBox>

                <!-- Translated text color -->
                <GroupBox Header="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Grp_TranslatedText]}" Margin="0,5,0,10" Padding="5">
                    <DockPanel Margin="0,5">
                        <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Lbl_TextColor]}" VerticalAlignment="Center" Width="120" />
                        <Button x:Name="translatedTextColorButton" 
                                Width="30" Height="20" 
                                Margin="5,0,0,0"
                                Click="TranslatedTextColorButton_Click"/>
                        <TextBlock x:Name="translatedTextColorText" 
                                   Text="#FFFFFFFF" 
                                   VerticalAlignment="Center" 
                                   Margin="10,0,0,0"/>
                    </DockPanel>
                </GroupBox>

                <!-- Text outline color -->
                <GroupBox Header="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Grp_TextOutline]}" Margin="0,5,0,10" Padding="5">
                    <DockPanel Margin="0,5">
                        <TextBlock Text="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Lbl_OutlineColor]}" VerticalAlignment="Center" Width="120" />
                        <Button x:Name="textOutlineColorButton" 
                                Width="30" Height="20" 
                                Margin="5,0,0,0"
                                Click="TextOutlineColorButton_Click"/>
                        <TextBlock x:Name="textOutlineColorText" 
                                   Text="#FF000000" 
                                   VerticalAlignment="Center" 
                                   Margin="10,0,0,0"/>
                    </DockPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <!-- Buttons section -->
        <Grid Grid.Row="2" Margin="0,15,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <Button x:Name="defaultsButton"
                    Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Btn_SetDefaults]}"
                    Width="100"
                    HorizontalAlignment="Left"
                    Click="DefaultsButton_Click"
                    ToolTip="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Tip_SetDefaults]}"
                    Grid.Column="0"/>
            
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Grid.Column="1">
                <Button x:Name="applyButton"
                        Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Btn_Apply]}"
                        Width="80"
                        Margin="5,0"
                        Click="ApplyButton_Click"/>
                <Button x:Name="cancelButton"
                        Content="{Binding Source={x:Static local:LocalizationManager.Instance}, Path=Strings[ChatBoxOptions_Btn_Cancel]}"
                        Width="80"
                        Margin="5,0"
                        Click="CancelButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>